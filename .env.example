# =========================================================================
# Free Traffic System - Cấu hình môi trường cho Docker Deployment
# Sao chép file này thành .env trong thư mục gốc và điền các thông tin của bạn.
# =========================================================================

# --- CẤU HÌNH LIÊN KẾT HỆ THỐNG ---
PORT=4000
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
JWT_SECRET=your-very-secure-jwt-secret-key-here

# --- NEXT.JS BUILD CONFIGURATION ---
# URL công khai của API Backend (sẽ được nhúng vào bundle của Next.js khi build image frontend)
# Khi deploy thật, đổi thành domain của bạn, ví dụ: http://your-domain-ip:4000/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# --- DATABASE & CACHE CONFIG (Dùng mặc định cho docker-compose) ---
# Nếu chạy qua docker-compose, các host sẽ là tên service: 'postgres' và 'redis'
DATABASE_URL=postgresql://admin:password@postgres:5432/freetraffic?sslmode=disable
REDIS_HOST=redis
REDIS_PORT=6379

# --- TÍCH HỢP TRÍ TUỆ NHÂN TẠO (AI PROVIDERS) ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=deepseek-chat
GEMINI_API_KEY=your-gemini-api-key-here

# --- TÍCH HỢP GOOGLE (Search Console & Analytics) ---
GA4_PROPERTY_ID=539718603
GSC_SITE_URL=https://your-domain.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- TÍCH HỢP FACEBOOK / META (Social Listening & Pages) ---
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# --- TÍCH HỢP ZALO (Zalo OA & Webhook) ---
ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=your-zalo-app-secret

# --- TÍCH HỢP TELEGRAM (Thông báo cảnh báo) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
