{
  "name": "free-traffic-system",
  "version": "1.0.0",
  "private": true,
  "description": "Free Traffic System Monorepo",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npx concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:push": "npm run db:push -w apps/backend",
    "db:generate": "npm run db:generate -w apps/backend",
    "check:backend": "powershell -ExecutionPolicy Bypass -File scripts/check-backend.ps1",
    "openspec": "openspec"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.4.1"
  }
}
