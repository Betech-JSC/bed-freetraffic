generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int             @id @default(autoincrement())
  email       String          @unique
  name        String?
  password    String
  role        Role            @default(EDITOR)
  isActive    Boolean         @default(true)
  totpSecret  String?
  totpEnabled Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspaces  UserWorkspace[]
  auditLogs   AuditLog[]
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model Workspace {
  id                Int                 @id @default(autoincrement())
  name              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  users             UserWorkspace[]
  channels          Channel[]
  keywordGroups     KeywordGroup[]
  seoKeywords       SeoKeyword[]
  googleInts        GoogleIntegration[]
  automations       AutomationTask[]
  templates         PostTemplate[]
  schedules         ContentSchedule[]
  seoAudits         SeoAudit[]
  backlinks         Backlink[]
  emailCampaigns    EmailCampaign[]
  customers         Customer[]
  alertRules        AlertRule[]
  abTests           AbTest[]
  socialConnections SocialConnection[]
  analyticsSnapshots AnalyticsSnapshot[]
  blogPosts         BlogPost[]
  landingPages      LandingPage[]
  customForms       CustomForm[]
  formSubmissions   FormSubmission[]
  emailWorkflows    EmailWorkflow[]
  emailWorkflowQueues EmailWorkflowQueue[]
  products          Product[]
  orders            Order[]
  paymentConfig     PaymentConfig?
  cskhConfig        CskhConfig?
  chatSessions      ChatSession[]
  auditLogs         AuditLog[]
  knowledgeChunks   KnowledgeChunk[]
  knowledgeSources  KnowledgeSource[]
  shortLinks        ShortLink[]
  popupWidgets      PopupWidget[]
  marketingWidgets  MarketingWidget[]
  socialListeningCampaigns SocialListeningCampaign[]
}

model UserWorkspace {
  id          Int       @id @default(autoincrement())
  userId      Int
  workspaceId Int
  role        String    @default("MEMBER") // OWNER, MEMBER, VIEWER
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Channel {
  id                Int              @id @default(autoincrement())
  name              String
  type              String
  url               String?
  status            String           @default("ACTIVE")
  apiConfig         String?
  connectionStatus  String           @default("DISCONNECTED")
  keywords          SeoKeyword[]
  workspaceId       Int?
  workspace         Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model KeywordGroup {
  id          Int          @id @default(autoincrement())
  name        String
  keywords    SeoKeyword[]
  workspaceId Int?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
}

model SeoKeyword {
  id              Int                  @id @default(autoincrement())
  keyword         String
  url             String?
  currentPosition Int?
  searchVolume    Int?
  channelId       Int?
  groupId         Int?
  channel         Channel?             @relation(fields: [channelId], references: [id], onDelete: SetNull)
  group           KeywordGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  rankHistory     KeywordRankHistory[]
  workspaceId     Int?
  workspace       Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model KeywordRankHistory {
  id          Int        @id @default(autoincrement())
  keywordId   Int
  keyword     SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  position    Int?
  clicks      Int?
  impressions Int?
  source      String     @default("manual")
  recordedAt  DateTime   @default(now())

  @@index([keywordId, recordedAt])
}

model GoogleIntegration {
  id            Int       @id @default(autoincrement())
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime?
  ga4PropertyId String?
  gscSiteUrl    String?
  lastSyncAt    DateTime?
  syncStatus    String    @default("DISCONNECTED")
  syncError     String?
  workspaceId   Int?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AnalyticsSnapshot {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  channelType String?
  sessions    Int      @default(0)
  users       Int      @default(0)
  pageviews   Int      @default(0)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  bounceRate  Float?
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([date, channelType, workspaceId])
}

model AutomationTask {
  id              Int            @id @default(autoincrement())
  name            String
  urlTarget            String
  platforms            String
  targetConnectionsJson String?
  emailRecipients      String?
  abTestId        Int?
  abTest          AbTest?        @relation(fields: [abTestId], references: [id], onDelete: SetNull)
  status          String         @default("STOPPED")
  interval        Int            @default(60)
  lastRunAt       DateTime?
  useAi           Boolean        @default(false)
  aiPrompt        String?
  aiGenerateImage Boolean        @default(false)
  rssUrl          String?
  rssLastPubDate  String?
  workspaceId     Int?
  workspace       Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  logs            BotLog[]
  templates       PostTemplate[]
}

model BotLog {
  id        Int            @id @default(autoincrement())
  taskId    Int
  task      AutomationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action    String
  message   String
  status    String         @default("SUCCESS")
  createdAt DateTime       @default(now())

  @@index([taskId, createdAt])
}

model SocialConnection {
  id          Int        @id @default(autoincrement())
  platform    String
  accessToken String
  pageName    String?
  pageId      String?
  status      String     @default("CONNECTED")
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([platform, pageId, workspaceId])
}

model PostTemplate {
  id           Int             @id @default(autoincrement())
  title        String
  content      String
  imageUrl     String?
  thumbnailUrl String?
  taskId       Int?
  task         AutomationTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  isActive     Boolean         @default(true)
  abTestsA     AbTest[]        @relation("VariantA")
  abTestsB     AbTest[]        @relation("VariantB")
  workspaceId  Int?
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// ——— Phase 2 ———

model ContentSchedule {
  id              Int        @id @default(autoincrement())
  title           String
  content         String
  imageUrl             String?
  platforms            String
  targetConnectionsJson String?
  urlTarget            String?
  recipients      String?
  scheduledAt     DateTime
  repeatRule      String?
  repeatUntil     DateTime?
  cronExpression  String?
  abTestId        Int?
  abTest          AbTest?    @relation(fields: [abTestId], references: [id], onDelete: SetNull)
  status          String     @default("PENDING")
  publishedAt     DateTime?
  errorMessage    String?
  channelResults  String?
  attemptCount    Int        @default(0)
  workspaceId     Int?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  overlayText      String?
  overlayWatermark String?
  overlayPosition  String?    @default("bottom-right")
  overlayFontSize  Int?       @default(32)
  assignedUserId  Int?
  utmTagEnabled   Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model SeoAudit {
  id              Int             @id @default(autoincrement())
  url             String
  score           Int
  technicalScore  Int
  contentScore    Int
  uxScore         Int
  workspaceId     Int?
  workspace       Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditedAt       DateTime        @default(now())
  issues          SeoAuditIssue[]
}

model SeoAuditIssue {
  id         Int      @id @default(autoincrement())
  auditId    Int
  audit      SeoAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  category   String
  severity   String
  message    String
  suggestion String?

  @@index([auditId])
}

model Backlink {
  id              Int        @id @default(autoincrement())
  sourceUrl       String
  targetUrl       String
  domainAuthority Int?
  pageAuthority   Int?
  linkType        String     @default("inbound")
  status          String     @default("active")
  checkedAt       DateTime?
  statusDetail    String?
  workspaceId     Int?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  discoveredAt    DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model EmailCampaign {
  id          Int          @id @default(autoincrement())
  name        String
  subject     String
  htmlContent String
  recipients  String
  status      String       @default("DRAFT")
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int          @default(0)
  openCount   Int          @default(0)
  clickCount  Int          @default(0)
  workspaceId Int?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  events      EmailEvent[]
}

model EmailEvent {
  id         Int           @id @default(autoincrement())
  campaignId Int
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  eventType  String
  recipient  String?
  createdAt  DateTime      @default(now())
}

// ——— Khách hàng & chăm sóc ———

model Customer {
  id            Int                @id @default(autoincrement())
  name          String
  email         String             @unique
  phone         String?
  zaloUserId    String?
  company       String?
  status        String             @default("NEW")
  lastContactAt DateTime?
  lastAiCareSentAt DateTime?
  workspaceId   Int?
  workspace     Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  trafficSource String?
  utmCampaign   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  notes         CustomerNote[]
  emailLogs     CustomerEmailLog[]
  orders              Order[]
  emailWorkflowQueues EmailWorkflowQueue[]
  chatSessions        ChatSession[]

  // Viral Referral fields
  referralCode   String?              @unique
  referredById   Int?
  referredBy     Customer?            @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals      Customer[]           @relation("Referrals")
  pointsBalance  Int                  @default(0)
  redemptions    ReferralRedemption[]

  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

model CustomerNote {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CustomerEmailLog {
  id           Int      @id @default(autoincrement())
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subject      String
  body         String
  status       String   @default("SENT")
  errorMessage String?
  sentAt       DateTime @default(now())
  channel      String   @default("email")

  @@index([customerId, sentAt])
}

// ——— Phase 3 ———

model AlertRule {
  id          Int        @id @default(autoincrement())
  name        String
  metric      String
  threshold   Float
  comparison  String     @default("lt")
  enabled     Boolean    @default(true)
  notifyEmail String?
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  logs        AlertLog[]
}

model AlertLog {
  id        Int       @id @default(autoincrement())
  ruleId    Int
  rule      AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  message   String
  severity  String    @default("WARNING")
  createdAt DateTime  @default(now())
}

model AbTest {
  id             Int               @id @default(autoincrement())
  name           String
  status         String            @default("RUNNING")
  templateAId    Int?
  templateBId    Int?
  templateA      PostTemplate?     @relation("VariantA", fields: [templateAId], references: [id], onDelete: SetNull)
  templateB      PostTemplate?     @relation("VariantB", fields: [templateBId], references: [id], onDelete: SetNull)
  landingPageAId Int?
  landingPageBId Int?
  landingPageA   LandingPage?      @relation("LpVariantA", fields: [landingPageAId], references: [id], onDelete: SetNull)
  landingPageB   LandingPage?      @relation("LpVariantB", fields: [landingPageBId], references: [id], onDelete: SetNull)
  impressionsA   Int               @default(0)
  impressionsB   Int               @default(0)
  clicksA        Int               @default(0)
  clicksB        Int               @default(0)
  winner         String?
  schedules      ContentSchedule[]
  automations    AutomationTask[]
  workspaceId    Int?
  workspace      Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model BlogPost {
  id           Int        @id @default(autoincrement())
  slug         String     @unique
  title        String
  summary      String?
  content      String
  htmlContent  String
  published    Boolean    @default(false)
  publishedAt  DateTime?
  authorName   String     @default("Admin")
  tags         String?
  targetKeyword String?
  workspaceId  Int?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ogImageUrl   String?    @db.Text

  @@index([workspaceId])
  @@index([slug])
}

model LandingPage {
  id           Int              @id @default(autoincrement())
  slug         String           @unique
  title        String
  layoutJson   String
  htmlContent  String
  cssContent   String?
  status       String           @default("DRAFT")
  fbPixelId            String?
  googleTagId          String?
  enableMessengerChat  Boolean          @default(false)
  workspaceId          Int?
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  forms        CustomForm[]
  abTestsA     AbTest[]         @relation("LpVariantA")
  abTestsB     AbTest[]         @relation("LpVariantB")
  targetKeyword String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  ogImageUrl   String?          @db.Text

  @@index([workspaceId])
  @@index([slug])
}

model CustomForm {
  id            Int              @id @default(autoincrement())
  name          String
  fieldsJson    String
  landingPageId Int?
  landingPage   LandingPage?     @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  workspaceId   Int?
  workspace     Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submissions   FormSubmission[]
  workflows     EmailWorkflow[]
  createdAt     DateTime         @default(now())

  @@index([workspaceId])
}

model FormSubmission {
  id          Int        @id @default(autoincrement())
  formId      Int
  form        CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  dataJson    String
  ipAddress   String?
  userAgent   String?
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([workspaceId])
  @@index([formId])
}

model EmailWorkflow {
  id            Int                  @id @default(autoincrement())
  name          String
  triggerType   String
  triggerFormId Int?
  form          CustomForm?          @relation(fields: [triggerFormId], references: [id], onDelete: SetNull)
  isActive      Boolean              @default(false)
  workspaceId   Int?
  workspace     Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps         EmailWorkflowStep[]
  queueJobs     EmailWorkflowQueue[]
  createdAt     DateTime             @default(now())

  @@index([workspaceId])
}

model EmailWorkflowStep {
  id            Int                  @id @default(autoincrement())
  workflowId    Int
  workflow      EmailWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder     Int
  actionType    String
  delaySeconds  Int                  @default(0)
  emailSubject  String?
  emailBody     String?
  queueJobs     EmailWorkflowQueue[]
  createdAt     DateTime             @default(now())

  @@index([workflowId])
}

model EmailWorkflowQueue {
  id            Int               @id @default(autoincrement())
  workflowId    Int
  workflow      EmailWorkflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId        Int
  step          EmailWorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  customerId    Int
  customer      Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  status        String            @default("PENDING")
  errorMessage  String?
  workspaceId   Int?
  workspace     Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())

  @@index([scheduledAt, status])
  @@index([customerId])
  @@index([workspaceId])
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Float
  currency    String      @default("VND")
  workspaceId Int?
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())

  referralRedemptions ReferralRedemption[]

  @@index([workspaceId])
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNumber   String      @unique
  customerId    Int
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  totalAmount   Float
  status        String      @default("PENDING")
  paymentMethod String?
  gatewayTxnId  String?
  source        String      @default("WEB")
  workspaceId   Int?
  workspace     Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([workspaceId])
  @@index([orderNumber])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float

  @@index([orderId])
}

model PaymentConfig {
  id                  Int        @id @default(autoincrement())
  workspaceId         Int?       @unique
  workspace           Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payosClientId       String?
  payosApiKey         String?
  payosChecksumKey    String?
  stripeSecretKey     String?
  stripeWebhookSecret String?
  sepayBankCode       String?
  sepayAccountNumber  String?
  sepayAccountName    String?
  sepayApikey         String?
  sepayWebhookSecret  String?
}

model CskhConfig {
  id                   Int        @id @default(autoincrement())
  workspaceId          Int?       @unique
  workspace            Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  liveChatEnabled      Boolean    @default(false)
  aiChatbotEnabled     Boolean    @default(false)
  knowledgeBaseText    String?
  knowledgeFiles       String?    @db.Text
  knowledgeUrls        String?    @db.Text
  notificationChannels String?
  // Cấu hình AI Auto-Followup
  followUpDelayHours   Int?       @default(0)   // Số giờ chờ trước khi gửi mail (0 = tắt)
  followUpEmailSubject String?
  followUpEmailBody    String?    @db.Text
  followUpTemplate     String?    @default("default")
  // Cấu hình AI Bot tự động chăm sóc khách hàng theo lịch & đa kênh
  autoCareEnabled      Boolean    @default(false)
  autoCareScheduleType String     @default("AFTER_CREATION")
  autoCareDelayHours   Int        @default(24)
  autoCareIntervalDays Int        @default(7)
  autoCareEmailSubject String?
  autoCareEmailBody    String?    @db.Text
  autoCareTemplate     String?    @default("default")
  autoCareChannels     String     @default("email")
  widgetSettings       String?    @db.Text
}

model ChatSession {
  id                  String        @id @default(uuid())
  workspaceId         Int
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerId          Int?
  customer            Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  ipAddress           String?
  userAgent           String?
  followUpScheduledAt DateTime?
  followUpSent        Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  messages            ChatMessage[]

  @@index([workspaceId])
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String      // "visitor" hoặc "bot"
  content   String      @db.Text
  imageUrl  String?
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  action      String    // Ví dụ: "EXPORT_CRM", "DELETE_ORDER", "UPDATE_GATEWAY_CONFIG"
  ipAddress   String?
  userAgent   String?
  details     String?   @db.Text // JSON lưu chi tiết sự thay đổi hoặc bản ghi bị tác động
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([action])
}

model KnowledgeSource {
  id            Int              @id @default(autoincrement())
  workspaceId   Int
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  type          String           // "FILE" | "URL" | "TEXT"
  status        String           @default("PROCESSING") // "PROCESSING", "COMPLETED", "FAILED"
  fileSize      Int?
  url           String?          // URL nguồn (nếu có)
  syncSchedule  String?          // e.g. "daily", "weekly"
  extractedText String?          @db.Text
  errorMessage  String?          @db.Text
  chunks        KnowledgeChunk[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([workspaceId])
}

model KnowledgeChunk {
  id          Int                          @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId    Int?
  sourceObj   KnowledgeSource?             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  source      String
  content     String                       @db.Text
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime                     @default(now())

  @@index([workspaceId])
}

model ShortLink {
  id           Int              @id @default(autoincrement())
  workspaceId  Int
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  code         String           @unique
  originalUrl  String           @db.Text
  title        String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  clicks       ShortLinkClick[]

  @@index([workspaceId])
  @@index([code])
}

model ShortLinkClick {
  id           Int        @id @default(autoincrement())
  shortLinkId  Int
  shortLink    ShortLink  @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)
  referrer     String?    @db.Text
  userAgent    String?    @db.Text
  deviceType   String?    // "mobile" | "desktop" | "tablet"
  ipAddress    String?
  country      String?
  clickedAt    DateTime   @default(now())

  @@index([shortLinkId])
  @@index([clickedAt])
}

model PopupWidget {
  id           Int        @id @default(autoincrement())
  workspaceId  Int
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  type         String     // "EXIT_INTENT" | "DELAY" | "SCROLL"
  delaySeconds Int        @default(5)
  scrollDepth  Int        @default(50)
  title        String
  description  String     @db.Text
  buttonText   String     @default("Đăng ký")
  formFields   String     @default("email") // e.g. "email", "email,name", "email,name,phone"
  themeColor   String     @default("#e85d26")
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([workspaceId])
}

model ReferralRedemption {
  id            Int      @id @default(autoincrement())
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  pointsSpent   Int
  downloadToken String   @unique
  createdAt     DateTime @default(now())

  @@index([customerId])
}

model MarketingWidget {
  id           Int        @id @default(autoincrement())
  workspaceId  Int
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  type         String     // "QUIZ" | "CALCULATOR"
  title        String
  description  String     @db.Text
  configJson   String     @db.Text // Questions list or custom formula configuration
  themeColor   String     @default("#e85d26")
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([workspaceId])
}

model SocialListeningCampaign {
  id               Int                   @id @default(autoincrement())
  name             String
  keywords         String                // Danh sách từ khóa ngăn cách bằng dấu phẩy
  excludeKeywords  String?               // Từ khóa phủ định loại trừ rác
  groupUrls        String                // URL hoặc ID các nhóm Facebook ngăn cách bằng dấu phẩy
  facebookCookie   String?               @db.Text // Lưu cookie đăng nhập của người dùng
  cookieStatus     String                @default("ACTIVE") // ACTIVE, EXPIRED, ERROR
  isActive         Boolean               @default(true)
  useAi            Boolean               @default(true)
  telegramEnabled  Boolean               @default(true)
  telegramBotToken String?
  telegramChatId   String?
  workspaceId      Int
  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scanInterval     Int                   @default(15)
  lastScannedAt    DateTime?
  minScore         Int                   @default(50)
  enableSemanticFilter Boolean             @default(false)
  semanticThreshold   Float               @default(0.70)
  targetAudience      String?             @db.Text
  scrapeComments      Boolean             @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  logs             SocialListeningLog[]

  @@index([workspaceId])
}

model SocialListeningLog {
  id          Int                     @id @default(autoincrement())
  campaignId  Int
  campaign    SocialListeningCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  postUrl     String                  @db.Text
  postAuthor  String
  authorAvatar String?
  postContent String                  @db.Text
  aiScore     Int                     @default(0)
  aiDecision  String                  @default("COLD") // HOT, WARM, COLD, SPAM
  aiReason    String?                 @db.Text
  aiDraftMsg  String?                 @db.Text
  status      String                  @default("PENDING") // NOTIFIED, IGNORED, ERROR
  errorMessage String?                @db.Text
  isComment   Boolean                 @default(false)
  commentId   String?
  parentPostAuthor String?
  createdAt   DateTime                @default(now())

  @@index([campaignId])
  @@index([createdAt])
}



