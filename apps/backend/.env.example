DATABASE_URL="postgresql://postgres:password@localhost:5432/freetraffic?schema=public"
PORT=4000
JWT_SECRET="your-secret-key"

# Google Analytics 4 (Property ID trong GA4 Admin)
GA4_PROPERTY_ID=539718603

# OAuth — cách khuyến nghị (Gmail admin, không cần thêm service account trong GA4)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback
# FRONTEND_URL=http://localhost:3000

# Google Search Console — URL property chính xác như trong GSC (vd: https://example.com/ hoặc sc-domain:example.com)
GSC_SITE_URL=https://your-domain.com/

# Email mặc định cho lên lịch (nếu form không nhập recipients)
# SCHEDULE_EMAIL_RECIPIENTS=you@example.com,team@example.com

# Cron production (header x-cron-secret hoặc ?secret=):
#   POST /api/schedules/dispatch-due      — bot hẹn giờ
#   POST /api/email-campaigns/dispatch-due — email SCHEDULED
# CRON_SECRET=your-random-secret
# API_PUBLIC_URL=https://your-domain.com

# Phase 3 — AI & tích hợp
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# MAX_SEO_AUDITS_PER_DAY=20
# MOZ_ACCESS_ID=
# MOZ_SECRET_KEY=
# MAILCHIMP_API_KEY=
# MAILCHIMP_SERVER_PREFIX=us21

# Facebook OAuth + kiểm tra quyền token (debug_token)
# META_APP_ID=1514941420281648
# META_APP_SECRET=your-app-secret
# FB_GRAPH_VERSION=v21.0
# FB_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement,pages_manage_posts
